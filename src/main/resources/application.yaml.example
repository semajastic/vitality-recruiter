# Copy to application-local.yaml or export environment variables before running.
#
# Reddit credentials (required for postReddit):
#   REDDIT_USERNAME       - Reddit account username
#   REDDIT_PASSWORD       - Reddit account password
#   REDDIT_CLIENT_ID      - OAuth app client id
#   REDDIT_CLIENT_SECRET  - OAuth app client secret
#   REDDIT_SUBREDDIT      - Target subreddit name (no r/ prefix), e.g. ClashOfClansRecruit
#
# Example:
#   export REDDIT_USERNAME=my_bot_user
#   export REDDIT_PASSWORD=secret
#   export REDDIT_CLIENT_ID=abc123
#   export REDDIT_CLIENT_SECRET=xyz789
#   export REDDIT_SUBREDDIT=ClashOfClansRecruit

spring:
  application:
    name: coc-reddit-recruitter

app-config:
  zone: America/New_York
  clan-max-size: 50
  cwl-blackout-start-day: 1
  cwl-blackout-end-day: 10

clashhitters:
  clan-tag: "#YOURCLANTAG"
  base-url: https://clashhitters.com
  recruit-stats-uri: /api/recruit-stats-data

reddit:
  token-base-url: https://www.reddit.com
  token-uri: /api/v1/access_token
  grant-type: password
  submit-base-url: https://oauth.reddit.com
  submit-uri: /api/submit
  subreddit: ${REDDIT_SUBREDDIT:}
  username: ${REDDIT_USERNAME:}
  password: ${REDDIT_PASSWORD:}
  client-id: ${REDDIT_CLIENT_ID:}
  client-secret: ${REDDIT_CLIENT_SECRET:}
